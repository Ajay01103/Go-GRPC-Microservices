# ─── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=authdb
POSTGRES_PORT=5433

# Full DSN used by the auth service directly
AUTH_DB_URL=postgres://postgres:postgres@localhost:5433/authdb?sslmode=disable

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_PORT=6379
REDIS_URL=redis://:redispass@localhost:6379/0

# ─── Auth Service ─────────────────────────────────────────
AUTH_GRPC_PORT=50051

# ─── JWT ──────────────────────────────────────────────────
# Must be at least 32 characters for HS256
JWT_SECRET=supersecretjwtkey_changethis_in_production

# Go duration strings: 15m, 1h, 168h etc.
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h

# ─── Voice Service ────────────────────────────────────────
VOICE_GRPC_PORT=50052
VOICE_DB_PORT=5434
VOICE_DB_URL=postgres://postgres:postgres@localhost:5434/voicedb?sslmode=disable

# ─── Generation Service ───────────────────────────────────
GENERATION_GRPC_PORT=50053
GENERATION_DB_PORT=5435
GENERATION_DB_URL=postgres://postgres:postgres@localhost:5435/generationdb?sslmode=disable