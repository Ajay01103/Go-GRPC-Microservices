# ─── JWT & JWKS ──────────────────────────────────────────────────────────────
# JWKS endpoint URL for RS256 token validation (public)
NEXT_PUBLIC_AUTH_JWKS_URL=http://localhost:50051/.well-known/jwks.json

# Fallback JWT_SECRET for HS256 validation (legacy, maintain during migration)
JWT_SECRET=supersecretjwtkey_changethis_in_prod

# ─── Backblaze B2 S3 ─────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── TTS Proxy──────────────────────────
GENERATION_TTS_ENDPOINT=https://your-modal-server.modal.run/generate
GENERATION_TTS_API_KEY=YhHOZLH6ysFoq____ # any random string used in generation service secret