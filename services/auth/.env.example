GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5433/authdb?sslmode=disable
GOOSE_MIGRATION_DIR=db/migrations

# Full DSN used by the auth service directly
AUTH_DB_URL=postgres://postgres:postgres@localhost:5433/authdb?sslmode=disable

# ─── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=redispass
REDIS_PORT=6379
REDIS_URL=redis://:redispass@localhost:6379/0

# ─── Auth Service ─────────────────────────────────────────
AUTH_GRPC_PORT=50051

# ─── JWT ──────────────────────────────────────────────────
# Must be at least 32 characters for HS256
JWT_SECRET=supersecretjwtkey_changethis

# Go duration strings: 15m, 1h, 168h etc.
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h
