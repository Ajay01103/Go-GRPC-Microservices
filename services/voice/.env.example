# ─── Goose ────────────────────────────────────────────────────────────────────
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5434/voicedb?sslmode=disable
GOOSE_MIGRATION_DIR=db/migrations

# ─── Database ─────────────────────────────────────────────────────────────────
VOICE_DB_URL=postgres://postgres:postgres@localhost:5434/voicedb?sslmode=disable

# ─── gRPC ─────────────────────────────────────────────────────────────────────
VOICE_GRPC_PORT=50052

# redis
VOICE_REDIS_URL=redis://:redispass@localhost:6379/0

# ─── JWT & JWKS ──────────────────────────────────────────────
# JWKS mode (recommended): Fetch public keys from Auth service
# Leave empty or comment out to use JWT_SECRET mode instead
AUTH_SERVICE_JWKS_URL=http://auth:50051/.well-known/jwks.json

# Fallback to local JWT secret if JWKS URL is not set
# Must be at least 32 characters for HS256
JWT_SECRET=supersecretjwtkey_changethis_in_production

# ─── Backblaze B2 S3 ─────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=