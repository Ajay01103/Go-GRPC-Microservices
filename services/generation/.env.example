# ─── Goose ────────────────────────────────────────────────
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5435/generationdb?sslmode=disable
GOOSE_MIGRATION_DIR=db/migrations
GENERATION_DB_URL=postgres://postgres:postgres@localhost:5435/generationdb?sslmode=disable

# ─── JWT & JWKS ──────────────────────────────────────────────
# JWKS mode (recommended): Fetch public keys from Auth service
# Leave empty or comment out to use JWT_SECRET mode instead
AUTH_SERVICE_JWKS_URL=http://auth:50051/.well-known/jwks.json

# Fallback to local JWT secret if JWKS URL is not set
# Must be at least 32 characters for HS256
JWT_SECRET=supersecretjwtkey_changethis_in_production

CHATTERBOX_API_KEY=YhHOZLH6ysFoqr------ # make sure both are same (put any random string of your choice)
GENERATION_TTS_API_KEY=YhHOZLH6ysFoqr------# make sure both are same (put any random string of your choice)
GENERATION_CORS_ORIGIN=http://localhost:3000
GENERATION_TTS_ENDPOINT=https://your-modal-server.modal.run/generate # modal TTS generation endpoint
GENERATION_REDIS_URL=redis://:redispass@localhost:6379/0

# ____S3 (Backblaze B2)____
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=